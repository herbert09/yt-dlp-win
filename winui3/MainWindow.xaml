<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="YtDlpDownloader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="YtDlpDownloader">

    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="10" Spacing="8" VerticalAlignment="Center">
            <TextBox x:Name="txtUrl" PlaceholderText="输入视频链接" Width="400"/>
            <Button x:Name="btnDownload" Content="下载" Click="btnDownload_Click"/>
            <Button x:Name="btnSettings" Content="设置" Click="btnSettings_Click"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="tasksList" SelectionMode="Single" Padding="10,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" Padding="0,4" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Status}" Width="70" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="2" Value="{Binding Progress}" Maximum="100" Width="80" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding FileSize}" Width="70" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="{Binding DownloadTime}" Width="130" VerticalAlignment="Center"/>
                        <Button Grid.Column="5" Content="..." Padding="8,2">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="暂停" Click="Pause_Click" Tag="{Binding}"/>
                                    <MenuFlyoutItem Text="继续" Click="Resume_Click" Tag="{Binding}"/>
                                    <MenuFlyoutItem Text="复制链接" Click="Copy_Click" Tag="{Binding}"/>
                                    <MenuFlyoutItem Text="打开所在目录" Click="Open_Click" Tag="{Binding}"/>
                                    <MenuFlyoutItem Text="删除任务" Click="Delete_Click" Tag="{Binding}"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
